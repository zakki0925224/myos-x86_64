{
    "rust-analyzer.check.allTargets": false,
    "rust-analyzer.linkedProjects": [
        "./kernel/Cargo.toml"
    ],
    "rust-analyzer.check.workspace": false,
    "rust-analyzer.cargo.targetDir": true,
    "files.watcherExclude": {
        "**/target/**": true,
        "third-party/qemu/**": true,
        "build/**": true,
        "dump/**": true
    },
    "files.exclude": {
        "**/target": true,
        "third-party/qemu": true,
        "build": true,
        "dump": true
    },
    "search.exclude": {
        "**/target": true,
        "third-party/qemu": true,
        "build": true,
        "dump": true
    },
    "git.ignoredRepositories": [
        "third-party/qemu"
    ]
}
