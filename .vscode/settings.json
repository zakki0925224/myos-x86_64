{
    "rust-analyzer.check.allTargets": false,
    "rust-analyzer.linkedProjects": [
        "./kernel/Cargo.toml",
        "./bootloader/Cargo.toml",
        "./common/Cargo.toml",
        "./apps/libc-rs/Cargo.toml",
        "./apps/mandelbrot/Cargo.toml",
        "./apps/imgvw/Cargo.toml",
        "./apps/lifegame/Cargo.toml",
        "./apps/web/Cargo.toml"
    ],
    "files.watcherExclude": {
